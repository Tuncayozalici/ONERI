@model ONERI.Models.HataliParcaDashboardViewModel
@{
    ViewData["Title"] = "Hatalı Parça Analizi";

    var hataNedeniSayisi = Model.HataNedenLabels.Count;
    var bolumSayisi = Model.BolumLabels.Count;
    var operatorSayisi = Model.OperatorLabels.Count;
    var anaRenk = Model.RenkLabels.FirstOrDefault() ?? "Veri bulunamadı";
    var enYogunModul = Model.ModulHataAnalizleri.FirstOrDefault();
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/home-hatali-parca-dashboard.css" asp-append-version="true" />
}

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
}

<div class="hatali-page">
    <div class="container py-4 py-lg-5">
        <section class="hatali-hero mb-4">
            <div class="hatali-hero__content">
                <div class="hatali-hero__eyebrow">
                    <i class="bi bi-shield-exclamation"></i>
                    ANALIZ RAPORU
                </div>
                <h1>Hatalı Parça Analiz Ekranı</h1>
                <p>
                    Hatalı parça oranı, neden, bölüm, operatör ve modül yoğunluğunu tek analiz akışında izleyin.
                    Seçilen döneme göre trendler ve dağılımlar otomatik olarak yeniden hesaplanır.
                </p>
                <div class="hatali-hero__facts">
                    <div class="hatali-fact">
                        <span>Hata nedeni</span>
                        <strong>@hataNedeniSayisi</strong>
                    </div>
                    <div class="hatali-fact">
                        <span>Çalışılan iş günü</span>
                        <strong>@Model.CalisilanIsGunu</strong>
                    </div>
                    <div class="hatali-fact hatali-fact--wide">
                        <span>Öne çıkan neden</span>
                        <strong>@Model.EnCokHataNedeni</strong>
                    </div>
                    <div class="hatali-fact hatali-fact--wide">
                        <span>En çok hata operatörü</span>
                        <strong>@Model.EnCokOperator</strong>
                    </div>
                </div>
            </div>

            <div class="hatali-hero__panel">
                <form asp-action="HataliParcaDashboard" method="get" class="hatali-filter-form js-unified-date-filter-form">
                    @await Html.PartialAsync("_UnifiedDateFilter")
                    <div class="hatali-filter-form__actions">
                        <button type="submit" class="btn btn-dark js-unified-filter-apply" disabled>Filtrele</button>
                        <button type="button" class="btn btn-outline-secondary js-unified-filter-clear" disabled>Temizle</button>
                    </div>
                </form>

                <div class="hatali-period">
                    @await Html.PartialAsync("_SelectedFilterPeriod", Model.RaporTarihi)
                </div>

                <div class="hatali-hero__note">
                    <p>
                        <strong>Hatalı parça oranı</strong>, hatalı parça adedinin toplam üretim adedine bölünmesiyle hesaplanır.
                    </p>
                    <p class="mb-0">
                        Hata nedenleri operasyonel kök nedenlere normalize edilir; bölüm grafiğindeki bir sütuna tıklayarak nedeni filtreleyebilirsiniz.
                    </p>
                </div>
            </div>
        </section>

        <section class="hatali-kpis mb-4">
            <article class="hatali-kpi hatali-kpi--rose">
                <span class="hatali-kpi__label">Hatalı Parça Oranı</span>
                <strong class="hatali-kpi__value">@Model.HataliParcaOrani.ToString("N2")%</strong>
                <small class="hatali-kpi__meta">@Model.ToplamHataAdet.ToString("N0") hatalı / @Model.ToplamUretimAdet.ToString("N0") üretim</small>
            </article>
            <article class="hatali-kpi hatali-kpi--cyan">
                <span class="hatali-kpi__label">En Çok Hata Bölümü</span>
                <strong class="hatali-kpi__value hatali-kpi__value--text">@Model.EnCokHataBolum</strong>
                <small class="hatali-kpi__meta">En yüksek hata yoğunluğu</small>
            </article>
            <article class="hatali-kpi hatali-kpi--violet">
                <span class="hatali-kpi__label">Aktif Operatör</span>
                <strong class="hatali-kpi__value">@operatorSayisi</strong>
                <small class="hatali-kpi__meta">Top 10 listesine giren operatör sayısı</small>
            </article>
            <article class="hatali-kpi hatali-kpi--stone">
                <span class="hatali-kpi__label">Yoğun Modül</span>
                <strong class="hatali-kpi__value hatali-kpi__value--text">@(enYogunModul?.Modul ?? anaRenk)</strong>
                <small class="hatali-kpi__meta">
                    @(enYogunModul != null ? $"{enYogunModul.HataPayi:N1}% hata payı" : "Hata yükünün yoğunlaştığı renk")
                    @if (Model.ModulAnaliziTahminiMi)
                    {
                        <span class="hatali-kpi__badge">tahmini veri</span>
                    }
                </small>
            </article>
        </section>

        <section class="row g-4">
            <div class="col-12 col-xl-8">
                <div class="hatali-panel h-100">
                    <div class="hatali-panel__header">
                        <div>
                            <h2>@(ViewBag.HataliTrendTitle ?? "Hatalı Parça Trendi")</h2>
                            <p>Hatalı parça oranını seçilen dönem akışında izleyin.</p>
                        </div>
                    </div>
                    <div class="hatali-panel__body hatali-panel__body--chart-lg">
                        <canvas id="hataAdetTrend"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-4">
                <div class="hatali-panel h-100">
                    <div class="hatali-panel__header">
                        <div>
                            <h2>Dönem Özeti</h2>
                            <p>Seçili tarih aralığı için hızlı okuma kartı.</p>
                        </div>
                    </div>
                    <div class="hatali-panel__body">
                        <div class="hatali-summary-list">
                            <div class="hatali-summary-item">
                                <span>Hatalı parça oranı</span>
                                <strong>@Model.HataliParcaOrani.ToString("N2")%</strong>
                            </div>
                            <div class="hatali-summary-item">
                                <span>Toplam hatalı adet</span>
                                <strong>@Model.ToplamHataAdet.ToString("N0")</strong>
                            </div>
                            <div class="hatali-summary-item">
                                <span>Toplam üretim</span>
                                <strong>@Model.ToplamUretimAdet.ToString("N0")</strong>
                            </div>
                            <div class="hatali-summary-item">
                                <span>En çok hata nedeni</span>
                                <strong>@Model.EnCokHataNedeni</strong>
                            </div>
                            <div class="hatali-summary-item">
                                <span>En çok hata bölümü</span>
                                <strong>@Model.EnCokHataBolum</strong>
                            </div>
                            <div class="hatali-summary-item">
                                <span>En çok hata operatörü</span>
                                <strong>@Model.EnCokOperator</strong>
                            </div>
                            <div class="hatali-summary-item">
                                <span>Toplam hata nedeni</span>
                                <strong>@hataNedeniSayisi</strong>
                            </div>
                            <div class="hatali-summary-item">
                                <span>Toplam bölüm</span>
                                <strong>@bolumSayisi</strong>
                            </div>
                            <div class="hatali-summary-item">
                                <span>Toplam operatör</span>
                                <strong>@operatorSayisi</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-6">
                <div class="hatali-panel h-100">
                    <div class="hatali-panel__header">
                        <div>
                            <h2 id="hataNedenPanelTitle">Hata Nedenleri</h2>
                            <p>Operasyonel kök neden payı; adet bilgisi tooltipte gösterilir.</p>
                        </div>
                    </div>
                    <div class="hatali-panel__body hatali-panel__body--chart-pie">
                        <canvas id="hataNedenGrafigi"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-6">
                <div class="hatali-panel h-100">
                    <div class="hatali-panel__header">
                        <div>
                            <h2>Bölüme Göre Hata</h2>
                            <p>Bölüm bazlı hata payı; bir sütuna tıklayarak neden panelini filtreleyin.</p>
                        </div>
                    </div>
                    <div class="hatali-panel__body hatali-panel__body--chart">
                        <canvas id="bolumGrafigi"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="hatali-panel h-100">
                    <div class="hatali-panel__header">
                        <div>
                            <h2>Operatöre Göre Hata</h2>
                            <p>En yüksek hata yüküne sahip operatörler.</p>
                        </div>
                    </div>
                    <div class="hatali-panel__body hatali-panel__body--chart">
                        <canvas id="operatorGrafigi"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="hatali-panel h-100">
                    <div class="hatali-panel__header">
                        <div>
                            <h2>Geçmiş Hata Nedenleri</h2>
                            <p>Son 3, 6 ve 12 ayda yoğunlaşan operasyonel kök nedenler.</p>
                        </div>
                    </div>
                    <div class="hatali-panel__body">
                        <div class="hatali-period-grid">
                            @foreach (var donem in Model.HataDonemAnalizleri)
                            {
                                <article class="hatali-period-card">
                                    <h3>@donem.Baslik</h3>
                                    @if (donem.NedenLabels.Any())
                                    {
                                        <div class="hatali-period-card__list">
                                            @for (var index = 0; index < donem.NedenLabels.Count; index++)
                                            {
                                                var pay = donem.NedenPayData.ElementAtOrDefault(index);
                                                var adet = donem.NedenAdetData.ElementAtOrDefault(index);
                                                var barWidth = Math.Min(100, Math.Max(2, pay)).ToString("N0");
                                                <div class="hatali-period-card__item">
                                                    <div>
                                                        <span>@donem.NedenLabels[index]</span>
                                                        <strong>@pay.ToString("N1")%</strong>
                                                    </div>
                                                    <small>@adet.ToString("N0") adet</small>
                                                    <i style="width:@barWidth%"></i>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="hatali-empty-state hatali-empty-state--compact">Bu dönem için veri bulunamadı.</div>
                                    }
                                </article>
                            }
                        </div>
                    </div>
                </div>
            </div>

        </section>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script id="hatali-parca-dashboard-data" type="application/json">
        @Html.Raw(Json.Serialize(new { model = Model }))
    </script>
    <script src="~/js/pages/dashboards/hatali-parca-dashboard.js" asp-append-version="true"></script>
}
