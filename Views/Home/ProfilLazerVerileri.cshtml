@model ONERI.Models.GunlukVerilerViewModel
@{
    ViewData["Title"] = "Profil Lazer Verileri";
    var aktifProfilSayisi = Model.ProfilIsimleri.Count;
    var aktifMakineSayisi = Model.MakineLabels.Count;
    var kayitGunSayisi = Model.Son7GunTarihleri.Count > 0 ? Model.Son7GunTarihleri.Count : 1;
    var oneCikanProfil = Model.ProfilIsimleri.FirstOrDefault() ?? "Profil kaydi yok";
    var baskinDuraklama = Model.DuraklamaNedenLabels.FirstOrDefault() ?? "Duraklama kaydi yok";
    var baskinMesai = Model.MesaiDurumuLabels.FirstOrDefault() ?? "Mesai kaydi yok";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/home-profil-lazer-dashboard.css" asp-append-version="true" />
}

@if (ViewBag.ErrorMessage != null)
{
    <div class="container py-4">
        <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
    </div>
}
else
{
    <div class="profile-page">
        <div class="container py-4 py-lg-5">
            <section class="profile-hero mb-4">
                <div class="profile-hero__content">
                    <div class="profile-hero__eyebrow">
                        <i class="bi bi-layers"></i>
                        OPERASYON RAPORU
                    </div>
                    <h1>Profil Lazer Operasyon Panosu</h1>
                    <p>
                        Uretim, sure, hatali urun ve hurda sinyallerini tek panel yapisinda izleyin.
                        KPI kartlari ve grafikler secilen doneme gore otomatik olarak yeniden hesaplanir.
                    </p>

                    <div class="profile-hero__facts">
                        <div class="profile-fact">
                            <span>Kayit gunu</span>
                            <strong>@kayitGunSayisi</strong>
                        </div>
                        <div class="profile-fact">
                            <span>Aktif makine</span>
                            <strong>@aktifMakineSayisi</strong>
                        </div>
                        <div class="profile-fact profile-fact--wide">
                            <span>One cikan profil</span>
                            <strong>@oneCikanProfil</strong>
                        </div>
                        <div class="profile-fact profile-fact--wide">
                            <span>Baskin duraklama</span>
                            <strong>@baskinDuraklama</strong>
                        </div>
                    </div>
                </div>

                <div class="profile-hero__panel">
                    <form asp-action="ProfilLazerVerileri" method="get" class="profile-filter-form js-unified-date-filter-form">
                        @await Html.PartialAsync("_UnifiedDateFilter")
                        <div class="profile-filter-form__actions">
                            <button type="submit" class="btn btn-dark js-unified-filter-apply" disabled>Filtrele</button>
                            <button type="button" class="btn btn-outline-secondary js-unified-filter-clear" disabled>Temizle</button>
                        </div>
                    </form>

                    <div class="profile-period">
                        @await Html.PartialAsync("_SelectedFilterPeriod", Model.RaporTarihi)
                    </div>

                    <div class="profile-hero__note">
                        <p>
                            <strong>Toplam sure</strong> secilen donemde profil lazer operasyonu icin kaydedilen toplam calisma suresidir.
                            <strong>Ortalama sure</strong> toplam sure / toplam uretim uzerinden okunur.
                        </p>
                        <p class="mb-0">
                            <strong>Makine</strong>, <strong>mesai</strong> ve <strong>duraklama</strong> panelleri yeni lazer veri yapisindaki operasyon akisina gore guncellendi.
                            <strong>Baskin mesai durumu</strong> bu donemde en yogun sureye sahip kayit: @baskinMesai.
                        </p>
                    </div>
                </div>
            </section>

            <section class="profile-kpis mb-4">
                <article class="profile-kpi profile-kpi--cyan">
                    <span class="profile-kpi__label">Toplam Uretim</span>
                    <strong class="profile-kpi__value">@Model.GunlukToplamUretim.ToString("N0")</strong>
                    <small class="profile-kpi__meta">Secilen donemde uretilen toplam adet</small>
                </article>
                <article class="profile-kpi profile-kpi--amber">
                    <span class="profile-kpi__label">Toplam Sure</span>
                    <strong class="profile-kpi__value">@Model.GunlukToplamSure.ToString("N0") dk</strong>
                    <small class="profile-kpi__meta">Toplam operasyon suresi</small>
                </article>
                <article class="profile-kpi profile-kpi--violet">
                    <span class="profile-kpi__label">Ortalama Sure</span>
                    <strong class="profile-kpi__value">@Model.OrtalamaIslemSuresi.ToString("F2") dk/adet</strong>
                    <small class="profile-kpi__meta">Birim basina islem suresi</small>
                </article>
                <article class="profile-kpi profile-kpi--rose">
                    <span class="profile-kpi__label">Hatali Urun</span>
                    <strong class="profile-kpi__value">@Model.HataliUrunAdedi.ToString("N0")</strong>
                    <small class="profile-kpi__meta">Secilen donemde tespit edilen toplam hata</small>
                </article>
                <article class="profile-kpi profile-kpi--slate">
                    <span class="profile-kpi__label">Hurda</span>
                    <strong class="profile-kpi__value">@Model.HurdaAdedi.ToString("N0")</strong>
                    <small class="profile-kpi__meta">Hurda karari verilen toplam adet</small>
                </article>
            </section>

            <section class="row g-4">
                <div class="col-12 col-xl-6">
                    <div class="profile-panel h-100">
                        <div class="profile-panel__header">
                            <div>
                                <h2>Profil Tipine Gore Uretim Dagilimi</h2>
                                <p>Secilen donemde profil karmasinin adet bazli dagilimini inceleyin.</p>
                            </div>
                        </div>
                        <div class="profile-panel__body profile-panel__body--chart-pie">
                            <canvas id="pastaGrafigi"></canvas>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xl-6">
                    <div class="profile-panel h-100">
                        <div class="profile-panel__header">
                            <div>
                                <h2>@(ViewBag.TrendTitle ?? "Uretim Trendi")</h2>
                                <p>Gun bazli uretim akisini tek eksende izleyin.</p>
                            </div>
                        </div>
                        <div class="profile-panel__body profile-panel__body--chart">
                            <canvas id="cizgiGrafigi"></canvas>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xl-6">
                    <div class="profile-panel h-100">
                        <div class="profile-panel__header">
                            <div>
                                <h2>Makine Bazli Uretim</h2>
                                <p>Calisilan makinelerin toplam uretim hacmini karsilastirin.</p>
                            </div>
                        </div>
                        <div class="profile-panel__body profile-panel__body--chart">
                            <canvas id="makineUretimGrafigi"></canvas>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xl-6">
                    <div class="profile-panel h-100">
                        <div class="profile-panel__header">
                            <div>
                                <h2 id="duraklamaPanelTitle">Duraklama Nedenleri</h2>
                                <p id="duraklamaPanelDescription">Makine bazli filtrelemek icin soldaki grafikten bir makineye tiklayin.</p>
                            </div>
                        </div>
                        <div class="profile-panel__body profile-panel__body--chart-pie">
                            <canvas id="duraklamaNedenGrafigi"></canvas>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="profile-panel h-100">
                        <div class="profile-panel__header">
                            <div>
                                <h2>Profil Tipine Gore Sure Dagilimi</h2>
                                <p>Toplam sureden hangi profil tipinin ne kadar pay aldigini okuyun.</p>
                            </div>
                        </div>
                        <div class="profile-panel__body profile-panel__body--chart">
                            <canvas id="urunSureGrafigi"></canvas>
                        </div>
                    </div>
                </div>

            </section>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script id="profil-lazer-data" type="application/json">
        @Html.Raw(Json.Serialize(new { model = Model }))
    </script>
    <script src="~/js/pages/dashboards/profil-lazer.js" asp-append-version="true"></script>
}
