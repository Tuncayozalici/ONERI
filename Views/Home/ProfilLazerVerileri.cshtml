@model ONERI.Models.ProfilLazerDashboardViewModel
@{
    ViewData["Title"] = "Metal Verileri";
    var aktifMakineSayisi = Model.MakineLabels.Count;
    var aktifMusteriSayisi = Model.MusteriLabels.Count;
    var oneCikanProfil = Model.ProfilLabels.FirstOrDefault() ?? "Profil kaydı yok";
    var baskinDuraklama = Model.DuraklamaNedenLabels.FirstOrDefault() ?? "Duraklama kaydı yok";
    var baskinMesai = Model.MesaiDurumuLabels.FirstOrDefault() ?? "Mesai kaydı yok";
    var oneCikanMusteri = Model.MusteriLabels.FirstOrDefault() ?? "Müşteri kaydı yok";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/home-profil-lazer-dashboard.css" asp-append-version="true" />
}

@if (ViewBag.ErrorMessage != null)
{
    <div class="container py-4">
        <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
    </div>
}
else
{
    <div class="profile-page">
        <div class="container py-4 py-lg-5">
            <section class="profile-hero mb-4">
                <div class="profile-hero__content">
                    <div class="profile-hero__eyebrow">
                        <i class="bi bi-layers"></i>
                        METAL OPERASYON
                    </div>
                    <h1>Profil Lazer Verileri</h1>
                    <p>
                        Metal veri kayıt sayfasındaki yeni yapı üzerinden kullanılan süre, kalan süre,
                        hata, performans, kullanılabilirlik, kalite ve OEE değerlerini tek akışta izleyin.
                    </p>

                    <div class="profile-hero__facts profile-hero__facts--triple">
                        <div class="profile-fact">
                            <span>Çalışılan iş günü</span>
                            <strong>@Model.CalisilanIsGunu</strong>
                        </div>
                        <div class="profile-fact">
                            <span>Aktif makine</span>
                            <strong>@aktifMakineSayisi</strong>
                        </div>
                        <div class="profile-fact">
                            <span>Aktif müşteri</span>
                            <strong>@aktifMusteriSayisi</strong>
                        </div>
                        <div class="profile-fact profile-fact--wide">
                            <span>Öne çıkan profil</span>
                            <strong>@oneCikanProfil</strong>
                        </div>
                        <div class="profile-fact profile-fact--wide">
                            <span>Baskın duraklama</span>
                            <strong>@baskinDuraklama</strong>
                        </div>
                        <div class="profile-fact profile-fact--wide">
                            <span>Baskın müşteri ve mesai</span>
                            <strong>@oneCikanMusteri | @baskinMesai</strong>
                        </div>
                    </div>
                </div>

                <div class="profile-hero__panel">
                    <form asp-action="ProfilLazerVerileri" method="get" class="profile-filter-form js-unified-date-filter-form">
                        @await Html.PartialAsync("_UnifiedDateFilter")
                        <div class="profile-filter-form__actions">
                            <button type="submit" class="btn btn-dark js-unified-filter-apply" disabled>Filtrele</button>
                            <button type="button" class="btn btn-outline-secondary js-unified-filter-clear" disabled>Temizle</button>
                        </div>
                    </form>

                    <div class="profile-period">
                        @await Html.PartialAsync("_SelectedFilterPeriod", Model.RaporTarihi)
                    </div>

                    <div class="profile-hero__note">
                        <p>
                            <strong>Kullanılan süre</strong> ve <strong>kalan süre</strong> doğrudan yeni metal Excel’indeki süre kolonlarından okunur.
                            OEE skoru ayrıca performans, kullanılabilirlik ve kalite alanlarıyla çapraz kontrol edilir.
                        </p>
                        <p class="mb-0">
                            Makine OEE grafiğinde bir makine seçtiğinizde duraklama paneli yalnızca o makinenin kayıtlarına iner.
                            Hata serisi ise yeni sayfadaki <strong>HATA SAYISI</strong> kolonunu, veri yoksa eski hata dosyasını kullanır.
                        </p>
                    </div>
                </div>
            </section>

            <section class="profile-kpis profile-kpis--six mb-4">
                <article class="profile-kpi profile-kpi--cyan">
                    <span class="profile-kpi__label">Toplam Parça</span>
                    <strong class="profile-kpi__value">@Model.ToplamParcaSayisi.ToString("N0")</strong>
                    <small class="profile-kpi__meta">Seçilen dönemde kaydedilen toplam parça sayısı</small>
                </article>
                <article class="profile-kpi profile-kpi--amber">
                    <span class="profile-kpi__label">Kesilen Profil Boy</span>
                    <strong class="profile-kpi__value">@Model.ToplamKesilenProfilBoy.ToString("N0")</strong>
                    <small class="profile-kpi__meta">Profil boy toplamı</small>
                </article>
                <article class="profile-kpi profile-kpi--rose">
                    <span class="profile-kpi__label">Hata Sayısı</span>
                    <strong class="profile-kpi__value">@Model.ToplamHataSayisi.ToString("N0")</strong>
                    <small class="profile-kpi__meta">Aynı dönemde kaydedilen toplam hata</small>
                </article>
                <article class="profile-kpi profile-kpi--violet">
                    <span class="profile-kpi__label">Kullanılan Süre</span>
                    <strong class="profile-kpi__value">@Model.ToplamKullanilanSure.ToString("N0") dk</strong>
                    <small class="profile-kpi__meta">Operasyonda kullanılan toplam süre</small>
                </article>
                <article class="profile-kpi profile-kpi--slate">
                    <span class="profile-kpi__label">Kalan Süre</span>
                    <strong class="profile-kpi__value">@Model.ToplamKalanSure.ToString("N0") dk</strong>
                    <small class="profile-kpi__meta">Vardiya içinde kalan toplam süre</small>
                </article>
                <article class="profile-kpi profile-kpi--emerald">
                    <span class="profile-kpi__label">Ortalama OEE</span>
                    <strong class="profile-kpi__value">@Model.OrtalamaOee.ToString("N1")%</strong>
                    <small class="profile-kpi__meta">
                        Perf. @Model.OrtalamaPerformans.ToString("N1")% |
                        Kul. @Model.OrtalamaKullanilabilirlik.ToString("N1")% |
                        Kal. @Model.OrtalamaKalite.ToString("N1")%
                    </small>
                </article>
            </section>

            <section class="row g-4">
                <div class="col-12 col-xl-6">
                    <div class="profile-panel h-100">
                        <div class="profile-panel__header">
                            <div>
                                <h2>@(ViewBag.MetalTrendTitle ?? "OEE ve Bileşen Trendi")</h2>
                                <p>Performans, kullanılabilirlik, kalite ve OEE günlük akışını birlikte izleyin.</p>
                            </div>
                        </div>
                        <div class="profile-panel__body profile-panel__body--chart">
                            <canvas id="oeeTrendGrafigi"></canvas>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xl-6">
                    <div class="profile-panel h-100">
                        <div class="profile-panel__header">
                            <div>
                                <h2>Makine Bazlı OEE</h2>
                                <p>Makine ortalamalarını karşılaştırın. Duraklama panelini filtrelemek için çubuk seçin.</p>
                            </div>
                        </div>
                        <div class="profile-panel__body profile-panel__body--chart">
                            <canvas id="makineOeeGrafigi"></canvas>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xl-6">
                    <div class="profile-panel h-100">
                        <div class="profile-panel__header">
                            <div>
                                <h2>Makine Bazlı Süre Dengesi</h2>
                                <p>Kullanılan ve kalan süreyi aynı eksende görün.</p>
                            </div>
                        </div>
                        <div class="profile-panel__body profile-panel__body--chart">
                            <canvas id="sureDengeGrafigi"></canvas>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xl-6">
                    <div class="profile-panel h-100">
                        <div class="profile-panel__header">
                            <div>
                                <h2 id="duraklamaPanelTitle">Duraklama Nedenleri</h2>
                                <p id="duraklamaPanelDescription">Makine seçimi yapıldığında grafik sadece o makinenin kayıtlarını gösterir.</p>
                            </div>
                        </div>
                        <div class="profile-panel__body profile-panel__body--chart-pie">
                            <canvas id="duraklamaNedenGrafigi"></canvas>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xl-6">
                    <div class="profile-panel h-100">
                        <div class="profile-panel__header">
                            <div>
                                <h2>Profil Hammadde Dağılımı</h2>
                                <p>Parça yükünün hangi profil tiplerinde yoğunlaştığını izleyin.</p>
                            </div>
                        </div>
                        <div class="profile-panel__body profile-panel__body--chart-pie">
                            <canvas id="profilDagilimGrafigi"></canvas>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xl-6">
                    <div class="profile-panel h-100">
                        <div class="profile-panel__header">
                            <div>
                                <h2>Müşteri Bazlı Parça Yoğunluğu</h2>
                                <p>Toplam parça sayısına göre en yoğun müşteri akışını görün.</p>
                            </div>
                        </div>
                        <div class="profile-panel__body profile-panel__body--chart">
                            <canvas id="musteriGrafigi"></canvas>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xl-6">
                    <div class="profile-panel h-100">
                        <div class="profile-panel__header">
                            <div>
                                <h2>Günlük Hata Akışı</h2>
                                <p>Yeni veri ekranındaki hata kolonundan günlük toplama inin.</p>
                            </div>
                        </div>
                        <div class="profile-panel__body profile-panel__body--chart">
                            <canvas id="hataTrendGrafigi"></canvas>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script id="profil-lazer-data" type="application/json">
        @Html.Raw(Json.Serialize(new { model = Model }))
    </script>
    <script src="~/js/pages/dashboards/profil-lazer.js" asp-append-version="true"></script>
}
