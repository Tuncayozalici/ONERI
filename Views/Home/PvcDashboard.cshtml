@model ONERI.Models.PvcDashboardViewModel
@using System.Linq
@{
    ViewData["Title"] = "PVC Verileri";

    var queryStartDate = Context.Request.Query["startDate"].ToString();
    var queryEndDate = Context.Request.Query["endDate"].ToString();
    var queryRaporTarihi = Context.Request.Query["raporTarihi"].ToString();
    var queryBaslangicTarihi = Context.Request.Query["baslangicTarihi"].ToString();
    var queryBitisTarihi = Context.Request.Query["bitisTarihi"].ToString();

    var routeStartDate = !string.IsNullOrWhiteSpace(queryStartDate)
        ? queryStartDate
        : (!string.IsNullOrWhiteSpace(queryBaslangicTarihi) ? queryBaslangicTarihi : queryRaporTarihi);
    var routeEndDate = !string.IsNullOrWhiteSpace(queryEndDate)
        ? queryEndDate
        : (!string.IsNullOrWhiteSpace(queryBitisTarihi) ? queryBitisTarihi : queryRaporTarihi);

    var baseRouteValues = new
    {
        startDate = string.IsNullOrWhiteSpace(routeStartDate) ? null : routeStartDate,
        endDate = string.IsNullOrWhiteSpace(routeEndDate) ? null : routeEndDate
    };

    var tumMakinelerUrl = Url.Action("PvcDashboard", "Home", baseRouteValues);
    var selectedMachine = (Model.SeciliMakine ?? string.Empty).Trim();
    var hideMachineBasedCharts = selectedMachine.Equals("STREAM-B", StringComparison.OrdinalIgnoreCase)
                                 || selectedMachine.Equals("STREAM-C", StringComparison.OrdinalIgnoreCase)
                                 || selectedMachine.Equals("TURANLAR", StringComparison.OrdinalIgnoreCase);
    var activeMachineCount = Model.MakineKartlari.Count(x => x.Uretim > 0 || x.Oee > 0 || x.HataliParca > 0 || x.DuraklamaDakika > 0);
    var oneCikanMakine = Model.MakineKartlari
        .Where(x => x.Uretim > 0)
        .OrderByDescending(x => x.Uretim)
        .FirstOrDefault();
    var baskinDuraklama = Model.DuraklamaNedenLabels.FirstOrDefault();
    var clearUrl = string.IsNullOrWhiteSpace(selectedMachine)
        ? tumMakinelerUrl
        : Url.Action("PvcDashboard", "Home", new
        {
            startDate = (string?)null,
            endDate = (string?)null,
            makine = selectedMachine
        });
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/home-pvc-dashboard.css" asp-append-version="true" />
}

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
}

<div class="pvc-page">
    <div class="container py-4 py-lg-5">
        <section class="pvc-hero mb-4">
            <div class="pvc-hero__content">
                <div class="pvc-hero__eyebrow">
                    <i class="bi bi-bounding-box"></i>
                    OPERASYON RAPORU
                </div>
                <h1>
                    PVC Üretim Performans Ekranı
                    @if (!string.IsNullOrWhiteSpace(selectedMachine))
                    {
                        <span class="pvc-hero__tag">@selectedMachine</span>
                    }
                </h1>
                <p>
                    PVC hatlarının üretim, kalite, duraklama ve OEE verilerini tek mimaride izleyin.
                    Ana dashboard ve makine drilldown ekranları aynı tasarım dilini ve aynı veri mantığını paylaşır.
                </p>
                <div class="pvc-hero__facts">
                    <div class="pvc-fact">
                        <span>Aktif hat</span>
                        <strong>@activeMachineCount</strong>
                    </div>
                    <div class="pvc-fact">
                        <span>Seçim modu</span>
                        <strong>@(!string.IsNullOrWhiteSpace(selectedMachine) ? "Makine görünümü" : "Tüm hatlar")</strong>
                    </div>
                    <div class="pvc-fact pvc-fact--wide">
                        <span>Öne çıkan makine</span>
                        <strong>@(oneCikanMakine?.MakineAdi ?? "Veri bulunamadı")</strong>
                    </div>
                    <div class="pvc-fact pvc-fact--wide">
                        <span>Baskın duraklama</span>
                        <strong>@(!string.IsNullOrWhiteSpace(baskinDuraklama) ? baskinDuraklama : "Duraklama kaydı yok")</strong>
                    </div>
                </div>
            </div>

            <div class="pvc-hero__panel">
                @if (!string.IsNullOrWhiteSpace(selectedMachine))
                {
                    <a class="pvc-back-link" href="@tumMakinelerUrl">
                        <i class="bi bi-arrow-left"></i>
                        Tüm makineleri göster
                    </a>
                }

                <form asp-action="PvcDashboard" method="get" class="pvc-filter-form js-unified-date-filter-form" data-clear-url="@clearUrl">
                    @await Html.PartialAsync("_UnifiedDateFilter")
                    @if (!string.IsNullOrWhiteSpace(selectedMachine))
                    {
                        <input type="hidden" name="makine" value="@selectedMachine" />
                    }
                    <div class="pvc-filter-form__actions">
                        <button type="submit" class="btn btn-dark js-unified-filter-apply" disabled>Filtrele</button>
                        <button type="button" class="btn btn-outline-secondary js-unified-filter-clear" disabled>Temizle</button>
                    </div>
                </form>

                <div class="pvc-period">
                    @await Html.PartialAsync("_SelectedFilterPeriod", Model.RaporTarihi)
                </div>

                <div class="pvc-hero__note">
                    <p>
                        <strong>OEE</strong>, performans, kullanılabilirlik ve kalite bileşenlerinin birleşik sonucudur.
                        <strong>Fiili çalışma oranı</strong> hatların net çalışma davranışını okumak için özet kartta sunulur.
                    </p>
                    <p class="mb-0">
                        Alt makine kartları, drilldown ekranına tek tıkla geçiş sağlar.
                        Seçili makine varken tarih filtresi temizlense bile makine bağlamı korunur.
                    </p>
                </div>
            </div>
        </section>

        <section class="pvc-kpis mb-4">
            <article class="pvc-kpi pvc-kpi--cyan">
                <span class="pvc-kpi__label">Toplam Üretim (Metraj)</span>
                <strong class="pvc-kpi__value">@Model.ToplamUretimMetraj.ToString("N0")</strong>
                <small class="pvc-kpi__meta">Seçilen dönem toplam metrajı</small>
            </article>
            <article class="pvc-kpi pvc-kpi--amber">
                <span class="pvc-kpi__label">Toplam Parça</span>
                <strong class="pvc-kpi__value">@Model.ToplamParcaSayisi.ToString("N0")</strong>
                <small class="pvc-kpi__meta">Hatlardan çıkan toplam parça</small>
            </article>
            <article class="pvc-kpi pvc-kpi--rose">
                <span class="pvc-kpi__label">Toplam Duraklama</span>
                <strong class="pvc-kpi__value">@Model.ToplamDuraklamaDakika.ToString("N0") dk</strong>
                <small class="pvc-kpi__meta">Kayıtlı toplam kayıp süre</small>
            </article>
            <article class="pvc-kpi pvc-kpi--violet">
                <span class="pvc-kpi__label">Ortalama OEE</span>
                <strong class="pvc-kpi__value">@Model.OrtalamaOee.ToString("N2")%</strong>
                <small class="pvc-kpi__meta">Birleşik verim skoru</small>
            </article>
            <article class="pvc-kpi pvc-kpi--emerald">
                <span class="pvc-kpi__label">Performans</span>
                <strong class="pvc-kpi__value">@Model.OrtalamaPerformans.ToString("N2")%</strong>
                <small class="pvc-kpi__meta">Hedefe göre üretim verimi</small>
            </article>
            <article class="pvc-kpi pvc-kpi--indigo">
                <span class="pvc-kpi__label">Kullanılabilirlik</span>
                <strong class="pvc-kpi__value">@Model.OrtalamaKullanilabilirlik.ToString("N2")%</strong>
                <small class="pvc-kpi__meta">Planlanan sürede erişilebilirlik</small>
            </article>
            <article class="pvc-kpi pvc-kpi--stone">
                <span class="pvc-kpi__label">Kalite</span>
                <strong class="pvc-kpi__value">@Model.OrtalamaKalite.ToString("N2")%</strong>
                <small class="pvc-kpi__meta">Kalite kaybı sonrası net oran</small>
            </article>
            <article class="pvc-kpi pvc-kpi--slate">
                <span class="pvc-kpi__label">Toplam Hatalı Parça</span>
                <strong class="pvc-kpi__value">@Model.ToplamHataliParca.ToString("N0")</strong>
                <small class="pvc-kpi__meta">Hata kaydına düşen toplam parça</small>
            </article>
        </section>

        <section class="row g-4">
            <div class="col-12 col-xl-8">
                <div class="pvc-panel h-100">
                    <div class="pvc-panel__header">
                        <div>
                            <h2>@(ViewBag.PvcOeeTitle ?? "OEE Skoru Trendi")</h2>
                            <p>Seçili dönemde OEE hareketini zamansal akışta takip edin.</p>
                        </div>
                    </div>
                    <div class="pvc-panel__body pvc-panel__body--chart-lg">
                        <canvas id="oeeTrendGrafigi"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-4">
                <div class="pvc-panel h-100">
                    <div class="pvc-panel__header">
                        <div>
                            <h2>Dönem Özeti</h2>
                            <p>Seçili aralık ve makine bağlamı için hızlı okuma kartı.</p>
                        </div>
                    </div>
                    <div class="pvc-panel__body">
                        <div class="pvc-summary-list">
                            <div class="pvc-summary-item">
                                <span>Seçili aralık</span>
                                <strong>@ViewBag.PvcRange</strong>
                            </div>
                            <div class="pvc-summary-item">
                                <span>Fiili çalışma oranı</span>
                                <strong>@Model.OrtalamaFiiliCalismaOrani.ToString("N2")%</strong>
                            </div>
                            <div class="pvc-summary-item">
                                <span>Makine filtresi</span>
                                <strong>@(!string.IsNullOrWhiteSpace(selectedMachine) ? selectedMachine : "Tüm makineler")</strong>
                            </div>
                            <div class="pvc-summary-item">
                                <span>En yüksek üretim</span>
                                <strong>@(oneCikanMakine?.MakineAdi ?? "Veri bulunamadı")</strong>
                            </div>
                            <div class="pvc-summary-item">
                                <span>Toplam kayıtlı duraklama nedeni</span>
                                <strong>@Model.DuraklamaNedenLabels.Count</strong>
                            </div>
                            <div class="pvc-summary-item">
                                <span>Hata yükü</span>
                                <strong>@Model.ToplamHataliParca.ToString("N0") parça</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-8">
                <div class="pvc-panel h-100">
                    <div class="pvc-panel__header">
                        <div>
                            <h2>@(ViewBag.UretimTrendTitle ?? "Üretim Trendi")</h2>
                            <p>Metraj hareketini günlük ritim içinde izleyin.</p>
                        </div>
                    </div>
                    <div class="pvc-panel__body pvc-panel__body--chart-lg">
                        <canvas id="uretimTrendGrafigi"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-4">
                <div class="pvc-panel h-100">
                    <div class="pvc-panel__header">
                        <div>
                            <h2>Makine Özeti</h2>
                            <p>Hatların üretim, hata ve OEE sinyallerini tek blokta görün.</p>
                        </div>
                    </div>
                    <div class="pvc-panel__body">
                        <div class="pvc-machine-list">
                            @foreach (var kart in Model.MakineKartlari)
                            {
                                <article class="pvc-machine-card @(selectedMachine.Equals(kart.MakineAdi, StringComparison.OrdinalIgnoreCase) ? "is-active" : string.Empty)">
                                    <div class="pvc-machine-card__top">
                                        <h3>@kart.MakineAdi</h3>
                                        <span>@kart.Oee.ToString("N1")% OEE</span>
                                    </div>
                                    <div class="pvc-machine-card__stats">
                                        <div>
                                            <span>Üretim</span>
                                            <strong>@kart.Uretim.ToString("N0")</strong>
                                        </div>
                                        <div>
                                            <span>Hatalı</span>
                                            <strong>@kart.HataliParca.ToString("N0")</strong>
                                        </div>
                                        <div>
                                            <span>Duraklama</span>
                                            <strong>@kart.DuraklamaDakika.ToString("N0") dk</strong>
                                        </div>
                                    </div>
                                </article>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @if (!hideMachineBasedCharts)
            {
                <div class="col-12 col-xl-6">
                    <div class="pvc-panel h-100">
                        <div class="pvc-panel__header">
                            <div>
                                <h2>@(ViewBag.PvcMakineOeeTitle ?? "Makine Bazlı OEE Karşılaştırma")</h2>
                                <p>Hatların ortalama OEE değerlerini yatay düzlemde kıyaslayın.</p>
                            </div>
                        </div>
                        <div class="pvc-panel__body pvc-panel__body--chart">
                            <canvas id="makineOeeTrendGrafigi"></canvas>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xl-6">
                    <div class="pvc-panel h-100">
                        <div class="pvc-panel__header">
                            <div>
                                <h2>Makine Bazlı Üretim (Metraj)</h2>
                                <p>Hat bazında toplam metraj karşılaştırması.</p>
                            </div>
                        </div>
                        <div class="pvc-panel__body pvc-panel__body--chart">
                            <canvas id="makineUretimGrafigi"></canvas>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-xl-6">
                    <div class="pvc-panel h-100">
                        <div class="pvc-panel__header">
                            <div>
                                <h2>Makine Bazlı Üretilen Parça</h2>
                                <p>Parça hacminin makine bazlı dağılımı.</p>
                            </div>
                        </div>
                        <div class="pvc-panel__body pvc-panel__body--chart">
                            <canvas id="makineParcaGrafigi"></canvas>
                        </div>
                    </div>
                </div>
            }

            <div class="col-12 col-xl-@(hideMachineBasedCharts ? "6" : "6")">
                <div class="pvc-panel h-100">
                    <div class="pvc-panel__header">
                        <div>
                            <h2>Performans / Kayıp Süre</h2>
                            <p>Performans oranı ile kayıp süre yüzdesini aynı eksende okuyun.</p>
                        </div>
                    </div>
                    <div class="pvc-panel__body pvc-panel__body--chart">
                        <canvas id="fiiliKayipGrafigi"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-@(hideMachineBasedCharts ? "6" : "6")">
                <div class="pvc-panel h-100">
                    <div class="pvc-panel__header">
                        <div>
                            <h2>Duraklama Nedenleri</h2>
                            <p>Kayıp sürelerin ana nedenlerini hacim bazlı dağılımda görün.</p>
                        </div>
                    </div>
                    <div class="pvc-panel__body pvc-panel__body--chart-pie">
                        <canvas id="duraklamaNedenGrafigi"></canvas>
                    </div>
                </div>
            </div>
        </section>

        @if (Model.MakineKartlari.Count > 1)
        {
            <section class="pvc-machine-links mt-4">
                <div class="pvc-panel">
                    <div class="pvc-panel__header">
                        <div>
                            <h2>Makine Ekranları</h2>
                            <p>Alt hat görünümüne tek tıkla geçin veya tüm makineler görünümüne dönün.</p>
                        </div>
                    </div>
                    <div class="pvc-panel__body">
                        <div class="pvc-machine-link-grid">
                            @foreach (var kart in Model.MakineKartlari)
                            {
                                var makineUrl = Url.Action("PvcDashboard", "Home", new
                                {
                                    startDate = string.IsNullOrWhiteSpace(routeStartDate) ? null : routeStartDate,
                                    endDate = string.IsNullOrWhiteSpace(routeEndDate) ? null : routeEndDate,
                                    makine = kart.MakineAdi
                                });
                                var isSelectedCard = selectedMachine.Equals(kart.MakineAdi, StringComparison.OrdinalIgnoreCase);

                                <a href="@makineUrl" class="pvc-machine-link-card @(isSelectedCard ? "is-selected" : string.Empty)">
                                    <div class="pvc-machine-link-card__icon">
                                        <i class="bi bi-cpu"></i>
                                    </div>
                                    <div class="pvc-machine-link-card__content">
                                        <div class="pvc-machine-link-card__top">
                                            <h3>@kart.MakineAdi Makinesi</h3>
                                            <span>@(isSelectedCard ? "Açık" : "Detaya Git")</span>
                                        </div>
                                        <p>Üretim: @kart.Uretim.ToString("N0") | Hatalı: @kart.HataliParca.ToString("N0") | OEE: @kart.Oee.ToString("N2")%</p>
                                    </div>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </section>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script id="pvc-dashboard-data" type="application/json">
        @Html.Raw(Json.Serialize(new { model = Model }))
    </script>
    <script src="~/js/pages/dashboards/pvc-dashboard.js" asp-append-version="true"></script>
}
