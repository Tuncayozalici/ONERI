@model ONERI.Models.SkipperDashboardViewModel
@using System.Linq
@{
    ViewData["Title"] = "Skipper Verileri";

    var queryStartDate = Context.Request.Query["startDate"].ToString();
    var queryEndDate = Context.Request.Query["endDate"].ToString();
    var queryRaporTarihi = Context.Request.Query["raporTarihi"].ToString();
    var queryBaslangicTarihi = Context.Request.Query["baslangicTarihi"].ToString();
    var queryBitisTarihi = Context.Request.Query["bitisTarihi"].ToString();

    var routeStartDate = !string.IsNullOrWhiteSpace(queryStartDate)
        ? queryStartDate
        : (!string.IsNullOrWhiteSpace(queryBaslangicTarihi) ? queryBaslangicTarihi : queryRaporTarihi);
    var routeEndDate = !string.IsNullOrWhiteSpace(queryEndDate)
        ? queryEndDate
        : (!string.IsNullOrWhiteSpace(queryBitisTarihi) ? queryBitisTarihi : queryRaporTarihi);

    var baseRouteValues = new
    {
        startDate = string.IsNullOrWhiteSpace(routeStartDate) ? null : routeStartDate,
        endDate = string.IsNullOrWhiteSpace(routeEndDate) ? null : routeEndDate
    };

    var cncOverviewUrl = Url.Action("CncDashboard", "Home", baseRouteValues);
    var dominantStop = Model.DuraklamaNedenLabels.FirstOrDefault() ?? "Duraklama kaydı yok";
    var machineLinks = new[]
    {
        new { Name = "Masterwood", Icon = "bi-tree", Url = Url.Action("MasterwoodDashboard", "Home", baseRouteValues), Summary = "Masterwood raporuna geç.", Active = false },
        new { Name = "Skipper", Icon = "bi-cpu", Url = Url.Action("SkipperDashboard", "Home", baseRouteValues), Summary = "Bu makineyi görüntülüyorsunuz.", Active = true },
        new { Name = "Rover-B", Icon = "bi-hdd-rack", Url = Url.Action("RoverBDashboard", "Home", baseRouteValues), Summary = "Rover-B raporuna geç.", Active = false }
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/home-cnc-dashboard.css" asp-append-version="true" />
}

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
}

<div class="cnc-page cnc-machine-page">
    <div class="container py-4 py-lg-5">
        <section class="cnc-hero mb-4">
            <div class="cnc-hero__content">
                <div class="cnc-hero__eyebrow">
                    <i class="bi bi-cpu"></i>
                    CNC MAKINESI
                </div>
                <h1>Skipper Uretim Raporu</h1>
                <p>
                    Skipper makinesinin delik, hata, duraklama ve OEE sinyallerini
                    CNC ana dashboard ile ayni gorsel dilde tek ekranda izleyin.
                </p>
                <a class="btn btn-outline-primary mt-2" href="@cncOverviewUrl">
                    <i class="bi bi-arrow-left"></i> Tum Makineleri Goster
                </a>

                <div class="cnc-hero__facts">
                    <div class="cnc-fact">
                        <span>Secili makine</span>
                        <strong>Skipper</strong>
                    </div>
                    <div class="cnc-fact">
                        <span>Ortalama kisi</span>
                        <strong>@Model.OrtalamaKisiSayisi.ToString("N1")</strong>
                    </div>
                    <div class="cnc-fact cnc-fact--wide">
                        <span>Baskin duraklama</span>
                        <strong>@dominantStop</strong>
                    </div>
                    <div class="cnc-fact cnc-fact--wide">
                        <span>Fiili calisma</span>
                        <strong>@Model.OrtalamaFiiliCalismaOrani.ToString("N2")%</strong>
                    </div>
                </div>
            </div>

            <div class="cnc-hero__panel">
                <form asp-action="SkipperDashboard" method="get" class="cnc-filter-form js-unified-date-filter-form">
                    @await Html.PartialAsync("_UnifiedDateFilter")
                    <div class="cnc-filter-form__actions">
                        <button type="submit" class="btn btn-dark js-unified-filter-apply" disabled>Filtrele</button>
                        <button type="button" class="btn btn-outline-secondary js-unified-filter-clear" disabled>Temizle</button>
                    </div>
                </form>

                <div class="cnc-period">
                    @await Html.PartialAsync("_SelectedFilterPeriod", Model.RaporTarihi)
                </div>

                <div class="cnc-hero__note">
                    <p>
                        <strong>Toplam delik</strong> Skipper hattinin ana uretim hacmidir.
                        <strong>Fiili calisma</strong> ve <strong>OEE</strong> birlikte okundugunda verimlilik dalgasini netlestirir.
                    </p>
                    <p class="mb-0">
                        Makine gecis kartlari CNC alt ekranlari arasinda hizli baglanti saglar.
                        Tarih filtresi bu gecislerde korunur.
                    </p>
                </div>
            </div>
        </section>

        <section class="cnc-machine-kpis mb-4">
            <article class="cnc-kpi cnc-kpi--cyan">
                <span class="cnc-kpi__label">Toplam Delik</span>
                <strong class="cnc-kpi__value">@Model.ToplamDelik.ToString("N0")</strong>
                <small class="cnc-kpi__meta">Makinenin toplam uretim cikisi</small>
            </article>
            <article class="cnc-kpi cnc-kpi--amber">
                <span class="cnc-kpi__label">Toplam Duraklama</span>
                <strong class="cnc-kpi__value">@Model.ToplamDuraklamaDakika.ToString("N0") dk</strong>
                <small class="cnc-kpi__meta">Kayitli toplam kayip sure</small>
            </article>
            <article class="cnc-kpi cnc-kpi--emerald">
                <span class="cnc-kpi__label">Performans</span>
                <strong class="cnc-kpi__value">@Model.OrtalamaPerformans.ToString("N2")%</strong>
                <small class="cnc-kpi__meta">Hedefe gore uretim verimi</small>
            </article>
            <article class="cnc-kpi cnc-kpi--cyan">
                <span class="cnc-kpi__label">Kullanilabilirlik</span>
                <strong class="cnc-kpi__value">@Model.OrtalamaKullanilabilirlik.ToString("N2")%</strong>
                <small class="cnc-kpi__meta">Hat erisilebilirligi</small>
            </article>
            <article class="cnc-kpi cnc-kpi--violet">
                <span class="cnc-kpi__label">Kalite</span>
                <strong class="cnc-kpi__value">@Model.OrtalamaKalite.ToString("N2")%</strong>
                <small class="cnc-kpi__meta">Kalite skoru</small>
            </article>
            <article class="cnc-kpi cnc-kpi--emerald">
                <span class="cnc-kpi__label">Fiili Calisma</span>
                <strong class="cnc-kpi__value">@Model.OrtalamaFiiliCalismaOrani.ToString("N2")%</strong>
                <small class="cnc-kpi__meta">Ortalama aktif calisma orani</small>
            </article>
            <article class="cnc-kpi cnc-kpi--violet">
                <span class="cnc-kpi__label">OEE</span>
                <strong class="cnc-kpi__value">@Model.OrtalamaOee.ToString("N2")%</strong>
                <small class="cnc-kpi__meta">Bilesik verim skoru</small>
            </article>
            <article class="cnc-kpi cnc-kpi--rose">
                <span class="cnc-kpi__label">Hatali Parca</span>
                <strong class="cnc-kpi__value">@Model.ToplamHataliParca.ToString("N0")</strong>
                <small class="cnc-kpi__meta">Secili donemde tespit edilen toplam hata</small>
            </article>
        </section>

        <section class="row g-4">
            <div class="col-12 col-xl-8">
                <div class="cnc-panel h-100">
                    <div class="cnc-panel__header">
                        <div>
                            <h2>@(ViewBag.SkipperTrendTitle ?? "Uretim Trendi")</h2>
                            <p>Toplam delik hacmini gunluk hareket halinde izleyin.</p>
                        </div>
                    </div>
                    <div class="cnc-panel__body cnc-panel__body--chart-lg">
                        <canvas id="uretimTrendGrafigi"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-4">
                <div class="cnc-panel h-100">
                    <div class="cnc-panel__header">
                        <div>
                            <h2>Donem Ozeti</h2>
                            <p>Secili aralik icin hizli okuma karti.</p>
                        </div>
                    </div>
                    <div class="cnc-panel__body">
                        <div class="cnc-summary-list">
                            <div class="cnc-summary-item">
                                <span>Secili tarih</span>
                                <strong>@Model.RaporTarihi.ToString("dd.MM.yyyy")</strong>
                            </div>
                            <div class="cnc-summary-item">
                                <span>Baskin duraklama</span>
                                <strong>@dominantStop</strong>
                            </div>
                            <div class="cnc-summary-item">
                                <span>Ortalama kisi</span>
                                <strong>@Model.OrtalamaKisiSayisi.ToString("N1")</strong>
                            </div>
                            <div class="cnc-summary-item">
                                <span>Fiili calisma</span>
                                <strong>@Model.OrtalamaFiiliCalismaOrani.ToString("N2")%</strong>
                            </div>
                            <div class="cnc-summary-item">
                                <span>Kalite</span>
                                <strong>@Model.OrtalamaKalite.ToString("N2")%</strong>
                            </div>
                            <div class="cnc-summary-item">
                                <span>OEE</span>
                                <strong>@Model.OrtalamaOee.ToString("N2")%</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-6">
                <div class="cnc-panel h-100">
                    <div class="cnc-panel__header">
                        <div>
                            <h2>@(ViewBag.SkipperOeeTitle ?? "OEE Skoru Trendi")</h2>
                            <p>Skipper verim skorunun gunluk hareketini takip edin.</p>
                        </div>
                    </div>
                    <div class="cnc-panel__body cnc-panel__body--chart">
                        <canvas id="oeeTrendGrafigi"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-6">
                <div class="cnc-panel h-100">
                    <div class="cnc-panel__header">
                        <div>
                            <h2>@(ViewBag.SkipperHataliTrendTitle ?? "Hatali Parca Trendi")</h2>
                            <p>Hatali parca kayitlarini gun bazinda izleyin.</p>
                        </div>
                    </div>
                    <div class="cnc-panel__body cnc-panel__body--chart">
                        <canvas id="hataliTrendGrafigi"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-6">
                <div class="cnc-panel h-100">
                    <div class="cnc-panel__header">
                        <div>
                            <h2>Duraklama Nedenleri</h2>
                            <p>Kayip sureyi olusturan ana nedenleri hacim bazli gorun.</p>
                        </div>
                    </div>
                    <div class="cnc-panel__body cnc-panel__body--chart-pie">
                        <canvas id="duraklamaNedenGrafigi"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-6">
                <div class="cnc-panel h-100">
                    <div class="cnc-panel__header">
                        <div>
                            <h2>Performans / Kayip Sure Trendleri</h2>
                            <p>Performans ve kayip sure oranlarini birlikte karsilastirin.</p>
                        </div>
                    </div>
                    <div class="cnc-panel__body cnc-panel__body--chart">
                        <canvas id="oranTrendGrafigi"></canvas>
                    </div>
                </div>
            </div>
        </section>

        <section class="cnc-machine-links mt-4">
            <div class="cnc-panel">
                <div class="cnc-panel__header">
                    <div>
                        <h2>Makine Ekranlari</h2>
                        <p>Masterwood, Skipper ve Rover-B detay ekranlari arasinda hizli gecis.</p>
                    </div>
                </div>
                <div class="cnc-panel__body">
                    <div class="cnc-machine-link-grid">
                        @foreach (var machine in machineLinks)
                        {
                            <a href="@machine.Url" class="cnc-machine-link-card @(machine.Active ? "cnc-machine-link-card--active" : string.Empty)">
                                <div class="cnc-machine-link-card__icon">
                                    <i class="bi @machine.Icon"></i>
                                </div>
                                <div class="cnc-machine-link-card__content">
                                    <div class="cnc-machine-link-card__top">
                                        <h3>@machine.Name Makinesi</h3>
                                        @if (machine.Active)
                                        {
                                            <span class="cnc-machine-link-card__badge">Aktif ekran</span>
                                        }
                                    </div>
                                    <p>@machine.Summary</p>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script id="cnc-machine-dashboard-data" type="application/json">
        @Html.Raw(Json.Serialize(new { model = Model, pageType = "skipper" }))
    </script>
    <script src="~/js/pages/dashboards/cnc-machine-dashboard.js" asp-append-version="true"></script>
}
