@model ONERI.Models.TezgahDashboardViewModel
@{
    ViewData["Title"] = "Tezgah Verileri";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/home-tezgah-dashboard.css" asp-append-version="true" />
}

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
}

<div class="tezgah-page">
    <div class="container py-4 py-lg-5">
        <section class="tezgah-hero mb-4">
            <div class="tezgah-hero__content">
                <div class="tezgah-hero__eyebrow">
                    <i class="bi bi-grid-1x2-fill"></i>
                    VERİ KAYIT
                </div>
                <h1>Tezgah Bölümü Performans Ekranı</h1>
                <p>
                    <strong>keson 2026</strong> dosyasındaki ürün, kayıp süre, hatalı parça, performans ve OEE kayıtlarını tek ekranda izleyin.
                    Tüm KPI kartları ve grafikler seçilen döneme göre günlük olarak yeniden toplanır.
                </p>
                <div class="tezgah-hero__facts tezgah-hero__facts--triple">
                    <div class="tezgah-fact">
                        <span>Çalışılan iş günü</span>
                        <strong>@Model.CalisilanIsGunu</strong>
                    </div>
                    <div class="tezgah-fact">
                        <span>Aktif ürün</span>
                        <strong>@Model.AktifUrunSayisi</strong>
                    </div>
                    <div class="tezgah-fact">
                        <span>Ortalama çalışan personel</span>
                        <strong>@Model.OrtalamaCalisanPersonel</strong>
                    </div>
                    <div class="tezgah-fact tezgah-fact--wide">
                        <span>Ort. günlük kapasite</span>
                        <strong>@Model.OrtalamaGunlukKapasite.ToString("N2")</strong>
                    </div>
                    <div class="tezgah-fact tezgah-fact--wide">
                        <span>Öne çıkan ürün</span>
                        <strong>@Model.OneCikanUrun</strong>
                    </div>
                    <div class="tezgah-fact tezgah-fact--wide">
                        <span>Baskın kayıp nedeni</span>
                        <strong>@Model.BaskinKayipNedeni</strong>
                    </div>
                </div>
            </div>

            <div class="tezgah-hero__panel">
                <form asp-action="TezgahDashboard" method="get" class="tezgah-filter-form js-unified-date-filter-form">
                    @await Html.PartialAsync("_UnifiedDateFilter")
                    <div class="tezgah-filter-form__actions">
                        <button type="submit" class="btn btn-dark js-unified-filter-apply" disabled>Filtrele</button>
                        <button type="button" class="btn btn-outline-secondary js-unified-filter-clear" disabled>Temizle</button>
                    </div>
                </form>

                <div class="tezgah-period">
                    @await Html.PartialAsync("_SelectedFilterPeriod", Model.RaporTarihi)
                </div>

                <div class="tezgah-hero__note">
                    <p>
                        <strong>Performans, kullanılabilirlik, kalite ve OEE</strong> değerleri artık doğrudan
                        <strong>VERİ KAYIT</strong> sayfasındaki kolonlardan okunur.
                    </p>
                    <p class="mb-0">
                        Gün içinde tekrarlanan satırlar aynı tarihte birleştirilir; günlük özet satırlarında tek kez girilen
                        kişi ve OEE değerleri de bu nedenle gün bazında normalize edilerek grafiklere yansıtılır.
                    </p>
                </div>
            </div>
        </section>

        <section class="tezgah-kpis mb-4">
            <article class="tezgah-kpi tezgah-kpi--emerald">
                <span class="tezgah-kpi__label">Toplam Parça</span>
                <strong class="tezgah-kpi__value">@Model.ToplamParcaAdeti.ToString("N0")</strong>
                <small class="tezgah-kpi__meta">Seçilen dönem üretim hacmi</small>
            </article>
            <article class="tezgah-kpi tezgah-kpi--cyan">
                <span class="tezgah-kpi__label">Toplam Kayıp Süre</span>
                <strong class="tezgah-kpi__value">@Model.ToplamKayipSureDakika.ToString("N0") dk</strong>
                <small class="tezgah-kpi__meta">Kayıtlı duruş nedenlerinin toplamı</small>
            </article>
            <article class="tezgah-kpi tezgah-kpi--violet">
                <span class="tezgah-kpi__label">Toplam Hatalı Parça</span>
                <strong class="tezgah-kpi__value">@Model.ToplamHataliParcaSayisi.ToString("N0")</strong>
                <small class="tezgah-kpi__meta">Seçilen dönemde girilen hatalı parça sayısı</small>
            </article>
            <article class="tezgah-kpi tezgah-kpi--stone">
                <span class="tezgah-kpi__label">Ortalama OEE</span>
                <strong class="tezgah-kpi__value">@Model.OrtalamaOee.ToString("N1")%</strong>
                <small class="tezgah-kpi__meta">Pozitif günlük OEE kayıtlarının ortalaması</small>
            </article>
        </section>

        <section class="row g-4">
            <div class="col-12 col-xl-8">
                <div class="tezgah-panel h-100">
                    <div class="tezgah-panel__header">
                        <div>
                            <h2>@(ViewBag.TezgahTrendTitle ?? "Parça ve Kayıp Süre Trendi")</h2>
                            <p>Günlük parça adedi ile kayıp süre hareketini birlikte izleyin.</p>
                        </div>
                    </div>
                    <div class="tezgah-panel__body tezgah-panel__body--chart-lg">
                        <canvas id="uretimSureGrafigi"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-4">
                <div class="tezgah-panel h-100">
                    <div class="tezgah-panel__header">
                        <div>
                            <h2>Dönem Özeti</h2>
                            <p>Seçili tarih aralığı için hızlı okuma kartı.</p>
                        </div>
                    </div>
                    <div class="tezgah-panel__body">
                        <div class="tezgah-summary-list">
                            <div class="tezgah-summary-item">
                                <span>Toplam ürün çeşidi</span>
                                <strong>@Model.AktifUrunSayisi</strong>
                            </div>
                            <div class="tezgah-summary-item">
                                <span>En yüksek üretim</span>
                                <strong>@Model.OneCikanUrun</strong>
                            </div>
                            <div class="tezgah-summary-item">
                                <span>En yüksek kayıp</span>
                                <strong>@Model.BaskinKayipNedeni</strong>
                            </div>
                            <div class="tezgah-summary-item">
                                <span>Ortalama kalite</span>
                                <strong>@Model.OrtalamaKalite.ToString("N1")%</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-6">
                <div class="tezgah-panel h-100">
                    <div class="tezgah-panel__header">
                        <div>
                            <h2>@(ViewBag.TezgahOeeTitle ?? "OEE, Performans ve Kalite Trendi")</h2>
                            <p>Günlük OEE, performans, kullanılabilirlik ve kalite seviyelerini karşılaştırın.</p>
                        </div>
                    </div>
                    <div class="tezgah-panel__body tezgah-panel__body--chart">
                        <canvas id="oeeKayipGrafigi"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-12 col-xl-6">
                <div class="tezgah-panel h-100">
                    <div class="tezgah-panel__header">
                        <div>
                            <h2>Ürün Bazlı Üretim</h2>
                            <p>Seçilen dönemde en yüksek üretim ve kayıp süre oluşturan ürünler.</p>
                        </div>
                    </div>
                    <div class="tezgah-panel__body tezgah-panel__body--chart">
                        <canvas id="urunGrafigi"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-12 col-xl-6">
                <div class="tezgah-panel h-100">
                    <div class="tezgah-panel__header">
                        <div>
                            <h2>Kayıp Süre Nedenleri</h2>
                            <p>Seçilen dönemde en fazla dakikayı oluşturan nedenler.</p>
                        </div>
                    </div>
                    <div class="tezgah-panel__body tezgah-panel__body--chart">
                        <canvas id="kayipNedenGrafigi"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-12 col-xl-6">
                <div class="tezgah-panel h-100">
                    <div class="tezgah-panel__header">
                        <div>
                            <h2>@(ViewBag.TezgahKosulTitle ?? "Çalışma Koşulu Kırılımı")</h2>
                            <p>Çalışma koşullarına göre parça adedi ve kayıp süre yoğunluğunu izleyin.</p>
                        </div>
                    </div>
                    <div class="tezgah-panel__body tezgah-panel__body--chart">
                        <canvas id="calismaKosuluGrafigi"></canvas>
                    </div>
                </div>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script id="tezgah-dashboard-data" type="application/json">
        @Html.Raw(Json.Serialize(new { model = Model, defaultYear = DateTime.Now.Year, resolvedYear = ViewBag.TezgahResolvedYear }))
    </script>
    <script src="~/js/pages/dashboards/tezgah-dashboard.js" asp-append-version="true"></script>
}
