@model ONERI.Models.OneriCreateViewModel

@{
    ViewData["Title"] = "Yeni Fikir Paylaş";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/oneri-yeni.css" asp-append-version="true" />
}

<div class="idea-page">
    <div class="container py-4 py-lg-5">
        <section class="idea-intro mb-4">
            <div class="idea-intro__copy">
                <div class="hero-kicker"><i class="bi bi-lightbulb"></i> Fikir Atölyesi</div>
                <h1>Yeni Fikir Paylaş</h1>
                <p>Fabrikamızın gelişimi için değerli fikirlerinizi kısa, net ve uygulanabilir biçimde paylaşın.</p>
            </div>
            <div class="idea-intro__meta">
                <div class="idea-intro__chip">
                    <i class="bi bi-rocket-takeoff"></i>
                    <span>Hızlı değerlendirme için açık anlatım</span>
                </div>
            </div>
        </section>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="idea-sidebar">
                    <div class="helper-card">
                        <h5>İpucu</h5>
                        <ul>
                            <li>Başlığı kısa ve net yaz.</li>
                            <li>Mevcut sorunu ve önerini ayrı belirt.</li>
                            <li>Beklenen etkiyi 1-2 cümleyle özetle.</li>
                        </ul>
                        <div class="helper-mini">
                            <i class="bi bi-shield-check"></i>
                            <div>
                                <strong>Gizlilik</strong>
                                <div>Bilgiler yalnızca yetkili ekiple paylaşılır.</div>
                            </div>
                        </div>
                    </div>

                    <div class="helper-card">
                        <h5>Adımlar</h5>
                        <ol>
                            <li>Bölüm seç</li>
                            <li>Fikri yaz</li>
                            <li>Gönder</li>
                        </ol>
                    </div>
                </div>
            </div>
            <div class="col-lg-8">
                <div class="form-card">
                    <div class="form-card__header">
                        <div>
                            <h2>Öneri Formu</h2>
                            <p>Formu doldurun, gerekli alanları tamamlayın ve önerinizi gönderin.</p>
                        </div>
                    </div>
                    <form asp-action="Yeni" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="form-card__section">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Bolum" class="form-label fw-semibold">İlgili Bölüm <span class="req">*</span></label>
                                <select asp-for="Bolum" asp-items="@ViewBag.Bolumler" class="form-select">
                                    <option value="" disabled selected>Lütfen bir bölüm seçiniz...</option>
                                </select>
                                <span asp-validation-for="Bolum" class="text-danger mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="CalistigiBolum" class="form-label fw-semibold">Çalıştığınız Bölüm <span class="req">*</span></label>
                                <select asp-for="CalistigiBolum" id="anaBolum" class="form-select">
                                    <option value="">Lütfen Bölüm Seçiniz...</option>
                                    <option value="InsanKaynaklari">İnsan Kaynakları</option>
                                    <option value="Panel">Panel Bölümü</option>
                                    <option value="Metal">Metal Bölümü</option>
                                    <option value="Muhasebe">Muhasebe</option>
                                    <option value="IT">IT</option>
                                </select>
                                <span asp-validation-for="CalistigiBolum" class="text-danger mt-1 d-block"></span>
                            </div>
                        </div>

                        <div id="altBolumKapsayici" class="mb-4 alt-birim">
                            <label asp-for="AltBolum" class="form-label fw-semibold">Alt Birim</label>
                            <select asp-for="AltBolum" id="altBolum" class="form-select">
                            </select>
                            <span asp-validation-for="AltBolum" class="text-danger mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Konu" class="form-label fw-semibold">Öneri Konusu <span class="req">*</span></label>
                            <input asp-for="Konu" class="form-control" placeholder="Önerinizin başlığını kısaca yazınız" />
                            <span asp-validation-for="Konu" class="text-danger mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Aciklama" class="form-label fw-semibold">Açıklama <span class="req">*</span></label>
                            <textarea asp-for="Aciklama" class="form-control" rows="7" placeholder="Önerinizi detaylandırın..."></textarea>
                            <span asp-validation-for="Aciklama" class="text-danger mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="OnerenKisi" class="form-label fw-semibold">Öneren Kişi <small class="text-muted">(İsteğe Bağlı)</small></label>
                            <input asp-for="OnerenKisi" class="form-control" placeholder="Adınız Soyadınız" />
                            <span asp-validation-for="OnerenKisi" class="text-danger mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="form-card__footer">
                        <div class="text-muted small">* işaretli alanlar zorunludur.</div>
                        <div class="form-card__actions">
                            <a asp-action="Index" asp-controller="FikirAtolyesi" class="btn btn-outline-secondary">Vazgeç</a>
                            <button type="submit" class="btn btn-dark btn-lg px-4">
                                <i class="bi bi-send me-1"></i> Gönder
                            </button>
                        </div>
                    </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/pages/oneri-yeni.js" asp-append-version="true"></script>
}
