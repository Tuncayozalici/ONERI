@inject Microsoft.AspNetCore.Authorization.IAuthorizationService AuthorizationService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ONERI</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/layout-shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/unified-date-filter.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ONERI.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Poppins:wght@300;400;500;700&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    <script src="~/js/theme-preload.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        var isAuthenticated = User.Identity?.IsAuthenticated == true;
        var canOneriAdmin = isAuthenticated &&
            (await AuthorizationService.AuthorizeAsync(User, null, Permissions.OneriAdmin.Access)).Succeeded;
        var canVeriYukle = isAuthenticated &&
            (await AuthorizationService.AuthorizeAsync(User, null, Permissions.VeriYukle.Create)).Succeeded;
        var isSuperAdmin = isAuthenticated && User.IsInRole(Permissions.SuperAdminRole);
    }
    <header>
        <nav class="navbar app-shell-navbar shadow-sm">
            <div class="container">
                <div class="d-flex align-items-center gap-2">
                    <button class="navbar-toggler btn border-0 shadow-sm app-shell-navbar__toggler" type="button" data-bs-toggle="offcanvas" data-bs-target="#yanMenu" aria-controls="yanMenu">
                        <i class="bi bi-list fs-4 app-shell-navbar__toggler-icon"></i>
                    </button>
                    <a class="navbar-brand d-flex align-items-center gap-1 app-shell-navbar__brand" asp-area="" asp-controller="Home" asp-action="Index">
                        <span class="fw-bold app-shell-navbar__brand-main">Marwood</span><span class="fw-light app-shell-navbar__brand-sub">Portal</span>
                    </a>
                </div>
                
                <div class="d-flex align-items-center">
                    <ul class="navbar-nav flex-row align-items-center gap-3">
                        <li class="nav-item d-none d-sm-block">
                            <a class="nav-link fw-semibold app-shell-navbar__link" asp-area="" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item d-none d-md-flex align-items-center">
                            <div class="form-check form-switch mb-0 d-flex align-items-center gap-2">
                                <input class="form-check-input" type="checkbox" id="themeToggle" role="switch" aria-label="Karanlık Mod">
                                <label class="form-check-label small app-shell-navbar__theme-label" for="themeToggle">
                                    <i class="bi bi-moon-stars me-1"></i>Karanlık
                                </label>
                            </div>
                        </li>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle user-chip" href="#" id="profilMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle"></i>
                                    @(User.FindFirst("AdSoyad")?.Value ?? User.Identity?.Name ?? "Kullanıcı")
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="profilMenu">
                                    <li>
                                        <span class="dropdown-item-text text-muted small">Profil Menüsü</span>
                                    </li>
                                    @if (canOneriAdmin)
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Admin" asp-action="Index">
                                                <i class="bi bi-shield-lock me-2"></i> Yönetim Paneli
                                            </a>
                                        </li>
                                    }
                                    @if (canVeriYukle)
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Admin" asp-action="VeriYukle">
                                                <i class="bi bi-upload me-2"></i> Veri Yükle
                                            </a>
                                        </li>
                                        <li>
                                            <button type="button"
                                                    class="dropdown-item js-gunluk-veri-modal-open"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#gunlukVeriIndirModal">
                                                <i class="bi bi-file-earmark-arrow-down me-2"></i> Günlük Verileri İndir
                                            </button>
                                        </li>
                                    }
                                    @if (isSuperAdmin)
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="SuperAdmin" asp-action="Index">
                                                <i class="bi bi-gear-wide-connected me-2"></i> Super Admin Paneli
                                            </a>
                                        </li>
                                    }
                                    @if (canOneriAdmin || canVeriYukle || isSuperAdmin)
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                    }
                                    <li>
                                        <form asp-area="" asp-controller="Login" asp-action="Logout" method="post" class="m-0">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="bi bi-box-arrow-right me-2"></i> Çıkış Yap
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-dark btn-sm" asp-area="" asp-controller="Login" asp-action="Index">Giriş Yap</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Yan Menü (Offcanvas) -->
    <div class="offcanvas offcanvas-start" tabindex="-1" id="yanMenu" aria-labelledby="yanMenuLabel">
      <div class="offcanvas-header border-bottom">
        <h5 class="offcanvas-title" id="yanMenuLabel">Menü</h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
      </div>
      <div class="offcanvas-body">
        @{
            var path = Context.Request.Path.Value?.ToLowerInvariant() ?? "";
            var gunlukActive = path.StartsWith("/home/gunlukveriler")
                || path.StartsWith("/home/profillazerverileri")
                || path.StartsWith("/home/boyahanedashboard")
                || path.StartsWith("/home/pvcdashboard")
                || path.StartsWith("/home/cncdashboard")
                || path.StartsWith("/home/masterwooddashboard")
                || path.StartsWith("/home/skipperdashboard")
                || path.StartsWith("/home/roverbdashboard")
                || path.StartsWith("/home/tezgahdashboard")
                || path.StartsWith("/home/ebatlamadashboard")
                || path.StartsWith("/home/hataliparcadashboard");
            var fikirActive = path.StartsWith("/fikiratolyesi")
                || path.StartsWith("/oneri/yeni")
                || path.StartsWith("/oneri/sorgula");

            var canGunluk = isAuthenticated && (await AuthorizationService.AuthorizeAsync(User, null, Permissions.Dashboards.GunlukVeriler)).Succeeded;
            var canProfil = isAuthenticated && (await AuthorizationService.AuthorizeAsync(User, null, Permissions.Dashboards.ProfilLazer)).Succeeded;
            var canBoyahane = isAuthenticated && (await AuthorizationService.AuthorizeAsync(User, null, Permissions.Dashboards.Boyahane)).Succeeded;
            var canPvc = isAuthenticated && (await AuthorizationService.AuthorizeAsync(User, null, Permissions.Dashboards.Pvc)).Succeeded;
            var canCnc = isAuthenticated && (await AuthorizationService.AuthorizeAsync(User, null, Permissions.Dashboards.Cnc)).Succeeded;
            var canTezgah = isAuthenticated && (await AuthorizationService.AuthorizeAsync(User, null, Permissions.Dashboards.Tezgah)).Succeeded;
            var canEbatlama = isAuthenticated && (await AuthorizationService.AuthorizeAsync(User, null, Permissions.Dashboards.Ebatlama)).Succeeded;
            var canHatali = isAuthenticated && (await AuthorizationService.AuthorizeAsync(User, null, Permissions.Dashboards.HataliParca)).Succeeded;

            var canFikirAtolyesi = true;
            var canOneriYeni = true;
            var canOneriSorgu = true;

            var hasGunlukChildren = canProfil || canBoyahane || canPvc || canCnc || canTezgah || canEbatlama || canHatali;
            var hasAnyGunluk = canGunluk || hasGunlukChildren;
            var hasFikirChildren = true;
            var hasAnyFikir = true;
        }
        <p class="text-muted small">MODÜLLER</p>
        <div class="list-group list-group-flush">
            @if (hasAnyGunluk)
            {
                <div class="list-group-item p-0 border-0">
                    <div class="d-flex align-items-center">
                        @if (canGunluk)
                        {
                            <a asp-controller="Home" asp-action="GunlukVeriler" class="flex-grow-1 d-flex align-items-center gap-2 px-3 py-2 text-dark text-decoration-none">
                                <i class="bi bi-calendar2-week fs-5"></i> Günlük Veriler
                            </a>
                        }
                        else
                        {
                            <span class="flex-grow-1 d-flex align-items-center gap-2 px-3 py-2 text-secondary">
                                <i class="bi bi-calendar2-week fs-5"></i> Günlük Veriler
                            </span>
                        }
                        @if (hasGunlukChildren)
                        {
                            <button class="btn btn-link text-dark px-3" type="button" data-bs-toggle="collapse" data-bs-target="#gunlukMenu" aria-expanded="@gunlukActive.ToString().ToLowerInvariant()" aria-controls="gunlukMenu">
                                <i class="bi bi-chevron-down"></i>
                            </button>
                        }
                    </div>
                    @if (hasGunlukChildren)
                    {
                        <div id="gunlukMenu" class="collapse @(gunlukActive ? "show" : "")">
                            <div class="list-group list-group-flush">
                                @if (canProfil)
                                {
                                    <a asp-controller="Home" asp-action="ProfilLazerVerileri" class="list-group-item list-group-item-action ps-5">
                                        <i class="bi bi-speedometer2 me-2"></i> Profil Lazer Bölümü
                                    </a>
                                }
                                @if (canBoyahane)
                                {
                                    <a asp-controller="Home" asp-action="BoyahaneDashboard" class="list-group-item list-group-item-action ps-5">
                                        <i class="bi bi-paint-bucket me-2"></i> Boyahane Bölümü
                                    </a>
                                }
                                @if (canPvc)
                                {
                                    <a asp-controller="Home" asp-action="PvcDashboard" class="list-group-item list-group-item-action ps-5">
                                        <i class="bi bi-bounding-box me-2"></i> PVC Bölümü
                                    </a>
                                }
                                @if (canCnc)
                                {
                                    <a asp-controller="Home" asp-action="CncDashboard" class="list-group-item list-group-item-action ps-5">
                                        <i class="bi bi-cpu me-2"></i> CNC Bölümü
                                    </a>
                                }
                                @if (canTezgah)
                                {
                                    <a asp-controller="Home" asp-action="TezgahDashboard" class="list-group-item list-group-item-action ps-5">
                                        <i class="bi bi-gear me-2"></i> Tezgah Bölümü
                                    </a>
                                }
                                @if (canEbatlama)
                                {
                                    <a asp-controller="Home" asp-action="EbatlamaDashboard" class="list-group-item list-group-item-action ps-5">
                                        <i class="bi bi-tools me-2"></i> Ebatlama Bölümü
                                    </a>
                                }
                                @if (canHatali)
                                {
                                    <a asp-controller="Home" asp-action="HataliParcaDashboard" class="list-group-item list-group-item-action ps-5">
                                        <i class="bi bi-bug me-2"></i> Hatalı Parça Analizi
                                    </a>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            @if (hasAnyFikir)
            {
                <div class="list-group-item p-0 border-0">
                    <div class="d-flex align-items-center">
                        @if (canFikirAtolyesi)
                        {
                            <a asp-controller="FikirAtolyesi" asp-action="Index" class="flex-grow-1 d-flex align-items-center gap-2 px-3 py-2 text-dark text-decoration-none">
                                <i class="bi bi-lightbulb fs-5"></i> Fikir Atölyesi
                            </a>
                        }
                        else
                        {
                            <span class="flex-grow-1 d-flex align-items-center gap-2 px-3 py-2 text-secondary">
                                <i class="bi bi-lightbulb fs-5"></i> Fikir Atölyesi
                            </span>
                        }
                        @if (hasFikirChildren)
                        {
                            <button class="btn btn-link text-dark px-3" type="button" data-bs-toggle="collapse" data-bs-target="#fikirMenu" aria-expanded="@fikirActive.ToString().ToLowerInvariant()" aria-controls="fikirMenu">
                                <i class="bi bi-chevron-down"></i>
                            </button>
                        }
                    </div>
                    @if (hasFikirChildren)
                    {
                        <div id="fikirMenu" class="collapse @(fikirActive ? "show" : "")">
                            <div class="list-group list-group-flush">
                                @if (canOneriYeni)
                                {
                                    <a asp-controller="Oneri" asp-action="Yeni" class="list-group-item list-group-item-action ps-5">
                                        <i class="bi bi-plus-circle me-2"></i> Yeni Öneri
                                    </a>
                                }
                                @if (canOneriSorgu)
                                {
                                    <a asp-controller="Oneri" asp-action="Sorgula" class="list-group-item list-group-item-action ps-5">
                                        <i class="bi bi-search me-2"></i> Öneri Sorgula
                                    </a>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            @if (canOneriAdmin)
            {
                <a asp-controller="Admin" asp-action="Index" class="list-group-item list-group-item-action d-flex align-items-center gap-2">
                    <i class="bi bi-shield-lock fs-5"></i> Yönetim Paneli
                </a>
            }
            @if (isSuperAdmin)
            {
                <a asp-controller="SuperAdmin" asp-action="Index" class="list-group-item list-group-item-action d-flex align-items-center gap-2">
                    <i class="bi bi-gear-wide-connected fs-5"></i> Super Admin Paneli
                </a>
            }
        </div>
      </div>
    </div>

    @if (canVeriYukle)
    {
        <div class="modal fade" id="gunlukVeriIndirModal" tabindex="-1" aria-labelledby="gunlukVeriIndirModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <form id="gunlukVeriIndirForm" method="get" asp-area="" asp-controller="Admin" asp-action="GunlukVerileriIndir">
                        <div class="modal-header">
                            <h5 class="modal-title" id="gunlukVeriIndirModalLabel">Günlük Verileri İndir</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Filtre Tipi</label>
                                <div class="d-flex flex-wrap gap-3">
                                    <div class="form-check">
                                        <input class="form-check-input js-gunluk-veri-filter-type" type="radio" name="gunlukVeriFiltreTipi" id="gunlukVeriFiltreGun" value="gun" checked>
                                        <label class="form-check-label" for="gunlukVeriFiltreGun">Gün</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input js-gunluk-veri-filter-type" type="radio" name="gunlukVeriFiltreTipi" id="gunlukVeriFiltreAy" value="ay">
                                        <label class="form-check-label" for="gunlukVeriFiltreAy">Ay</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input js-gunluk-veri-filter-type" type="radio" name="gunlukVeriFiltreTipi" id="gunlukVeriFiltreAralik" value="aralik">
                                        <label class="form-check-label" for="gunlukVeriFiltreAralik">Tarih Aralığı</label>
                                    </div>
                                </div>
                            </div>

                            <div id="gunlukVeriGunPanel" class="js-gunluk-veri-panel">
                                <label for="gunlukVeriGunInput" class="form-label">Gün Seç</label>
                                <input type="date" class="form-control" id="gunlukVeriGunInput" name="raporTarihi" value="@DateTime.Today.ToString("yyyy-MM-dd")">
                            </div>

                            <div id="gunlukVeriAyPanel" class="js-gunluk-veri-panel d-none">
                                <label for="gunlukVeriAyInput" class="form-label">Ay Seç</label>
                                <input type="month" class="form-control" id="gunlukVeriAyInput" value="@DateTime.Today.ToString("yyyy-MM")">
                                <input type="hidden" id="gunlukVeriAyHidden" name="ay">
                                <input type="hidden" id="gunlukVeriYilHidden" name="yil">
                            </div>

                            <div id="gunlukVeriAralikPanel" class="js-gunluk-veri-panel d-none">
                                <div class="row g-2">
                                    <div class="col-12 col-md-6">
                                        <label for="gunlukVeriBaslangicInput" class="form-label">Başlangıç Tarihi</label>
                                        <input type="date" class="form-control" id="gunlukVeriBaslangicInput" name="baslangicTarihi" value="@DateTime.Today.AddDays(-6).ToString("yyyy-MM-dd")">
                                    </div>
                                    <div class="col-12 col-md-6">
                                        <label for="gunlukVeriBitisInput" class="form-label">Bitiş Tarihi</label>
                                        <input type="date" class="form-control" id="gunlukVeriBitisInput" name="bitisTarihi" value="@DateTime.Today.ToString("yyyy-MM-dd")">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Vazgeç</button>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-download me-1"></i> PDF İndir
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }

    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - ONERI - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/components/unified-date-filter.js" asp-append-version="true"></script>
    <script src="~/js/components/chart-horizontal-percent-labels.js" asp-append-version="true"></script>
    <script>
        (function () {
            const modalElement = document.getElementById('gunlukVeriIndirModal');
            const form = document.getElementById('gunlukVeriIndirForm');
            if (!modalElement || !form) {
                return;
            }

            const filterTypeInputs = document.querySelectorAll('.js-gunluk-veri-filter-type');
            const gunPanel = document.getElementById('gunlukVeriGunPanel');
            const ayPanel = document.getElementById('gunlukVeriAyPanel');
            const aralikPanel = document.getElementById('gunlukVeriAralikPanel');

            const gunInput = document.getElementById('gunlukVeriGunInput');
            const ayInput = document.getElementById('gunlukVeriAyInput');
            const ayHidden = document.getElementById('gunlukVeriAyHidden');
            const yilHidden = document.getElementById('gunlukVeriYilHidden');
            const baslangicInput = document.getElementById('gunlukVeriBaslangicInput');
            const bitisInput = document.getElementById('gunlukVeriBitisInput');

            function setPanelState(activeType) {
                const isGun = activeType === 'gun';
                const isAy = activeType === 'ay';
                const isAralik = activeType === 'aralik';

                gunPanel.classList.toggle('d-none', !isGun);
                ayPanel.classList.toggle('d-none', !isAy);
                aralikPanel.classList.toggle('d-none', !isAralik);

                gunInput.disabled = !isGun;
                baslangicInput.disabled = !isAralik;
                bitisInput.disabled = !isAralik;
            }

            function getSelectedType() {
                const selected = Array.from(filterTypeInputs).find(x => x.checked);
                return selected ? selected.value : 'gun';
            }

            filterTypeInputs.forEach(input => {
                input.addEventListener('change', function () {
                    setPanelState(getSelectedType());
                });
            });

            form.addEventListener('submit', function () {
                ayHidden.value = '';
                yilHidden.value = '';

                const selectedType = getSelectedType();
                if (selectedType === 'ay' && ayInput.value) {
                    const parts = ayInput.value.split('-');
                    if (parts.length === 2) {
                        yilHidden.value = parts[0];
                        ayHidden.value = String(Number(parts[1]));
                    }
                }
            });

            document.querySelectorAll('.js-gunluk-veri-modal-open').forEach(button => {
                button.addEventListener('click', function () {
                    const openDropdown = button.closest('.dropdown-menu');
                    if (openDropdown) {
                        const parent = openDropdown.parentElement;
                        const toggle = parent ? parent.querySelector('[data-bs-toggle="dropdown"]') : null;
                        if (toggle) {
                            bootstrap.Dropdown.getOrCreateInstance(toggle).hide();
                        }
                    }
                });
            });

            setPanelState(getSelectedType());
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
