@model ONERI.Models.RoleEditViewModel
@{
    ViewData["Title"] = "Rol Yetkileri";
    var currentGroup = string.Empty;
    var gunlukDashboardPermissionKey = Permissions.Dashboards.GunlukVeriler;
    string ResolvePreviewTone(string group, string name)
    {
        if (group.Contains("Sipariş", StringComparison.OrdinalIgnoreCase)) return "blue";
        if (group.Contains("Fabrika", StringComparison.OrdinalIgnoreCase)) return "cyan";
        if (group.Contains("Akış", StringComparison.OrdinalIgnoreCase)) return "amber";
        if (group.Contains("SSH", StringComparison.OrdinalIgnoreCase)) return "green";
        if (group.Contains("Proses", StringComparison.OrdinalIgnoreCase)) return "slate";
        if (group.Contains("Grafik", StringComparison.OrdinalIgnoreCase)) return "teal";
        if (name.Contains("Hata", StringComparison.OrdinalIgnoreCase)) return "rose";
        return "violet";
    }

    string ResolvePreviewShape(string group, string name)
    {
        if (group.Contains("Proses", StringComparison.OrdinalIgnoreCase)) return "columns";
        if (group.Contains("Grafik", StringComparison.OrdinalIgnoreCase)) return "bars";
        if (name.Contains("OEE", StringComparison.OrdinalIgnoreCase)) return "gauge";
        if (name.Contains("Trend", StringComparison.OrdinalIgnoreCase)) return "line";
        if (name.Contains("Dağılım", StringComparison.OrdinalIgnoreCase)) return "donut";
        return "kpi";
    }

    var gunlukPreviewWidgets = Permissions.All
        .Where(permission => permission.Group.StartsWith("Günlük Veriler -", StringComparison.Ordinal))
        .Select(permission => new
        {
            permission.Key,
            Title = permission.Name,
            Description = permission.Group.Replace("Günlük Veriler - ", string.Empty),
            Tone = ResolvePreviewTone(permission.Group, permission.Name),
            Shape = ResolvePreviewShape(permission.Group, permission.Name)
        })
        .ToList();
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/superadmin-role-edit.css" asp-append-version="true" />
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between gap-2 mb-4">
        <div>
            <h1 class="h4 mb-1">@Model.RoleName</h1>
            <p class="text-muted mb-0">Rol yetkilerini güncelleyin.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="Roles">Geri Dön</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="role-permission-layout">
        <section class="card shadow-sm role-permission-editor" aria-labelledby="rolePermissionEditorTitle">
            <div class="card-body">
                <form asp-action="EditRole" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="RoleId" />
                    <input type="hidden" asp-for="RoleName" />

                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div id="rolePermissionEditorTitle" class="visually-hidden">Rol yetkileri listesi</div>
                    <div class="d-flex flex-column gap-3">
                        @for (var i = 0; i < Model.Permissions.Count; i++)
                        {
                            if (currentGroup != Model.Permissions[i].Group)
                            {
                                currentGroup = Model.Permissions[i].Group;
                                <div class="fw-semibold text-uppercase text-muted small mt-2">@currentGroup</div>
                            }
                            <div class="form-check">
                                <input type="hidden" asp-for="Permissions[i].Key" />
                                <input type="hidden" asp-for="Permissions[i].Name" />
                                <input type="hidden" asp-for="Permissions[i].Group" />
                                <input class="form-check-input js-role-permission"
                                       asp-for="Permissions[i].Selected"
                                       data-permission-key="@Model.Permissions[i].Key" />
                                <label class="form-check-label">@Model.Permissions[i].Name</label>
                            </div>
                        }
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a class="btn btn-outline-secondary" asp-action="Roles">İptal</a>
                        <button type="submit" class="btn btn-dark">Kaydet</button>
                    </div>
                </form>
            </div>
        </section>

        <aside class="role-dashboard-preview" aria-labelledby="gunlukPreviewTitle">
            <div class="role-dashboard-preview__sticky">
                <div class="role-dashboard-preview__header">
                    <span>Canlı ön izleme</span>
                    <h2 id="gunlukPreviewTitle">Günlük Veriler Panosu</h2>
                    <p>Yetki seçimleri değiştikçe bu rolün panoda göreceği kartlar burada güncellenir.</p>
                </div>

                <div id="gunlukRolePreview"
                     class="role-dashboard-preview__canvas"
                     data-dashboard-permission="@gunlukDashboardPermissionKey">
                    <div class="role-dashboard-preview__blocked" data-preview-blocked>
                        <i class="bi bi-lock" aria-hidden="true"></i>
                        <strong>Günlük Veriler erişimi kapalı</strong>
                        <span>Ön izleme için “Günlük Veriler (Özet)” yetkisini işaretleyin.</span>
                    </div>

                    <div class="role-dashboard-preview__screen" data-preview-screen hidden>
                        <div class="role-dashboard-preview__topbar">
                            <span data-preview-access-state>Günlük Veriler açık</span>
                            <strong><span data-preview-visible-count>0</span> kart görünür</strong>
                        </div>

                        <div class="role-dashboard-preview__hero">
                            <div>
                                <span class="role-dashboard-preview__eyebrow">FABRİKA ÖZETİ</span>
                                <h3>Günlük Veriler Panosu</h3>
                                <p>Seçili rolün erişebildiği özet kartları ve grafik alanları.</p>
                            </div>
                            <div class="role-dashboard-preview__facts">
                                <span>Seçili dönem</span>
                                <strong>01.04 - 15.04</strong>
                            </div>
                        </div>

                        <div class="role-dashboard-preview__widgets">
                            @foreach (var widget in gunlukPreviewWidgets)
                            {
                                <article class="role-dashboard-preview__widget role-dashboard-preview__widget--@widget.Tone role-dashboard-preview__widget--@widget.Shape"
                                         data-preview-widget
                                         data-permission-key="@widget.Key"
                                         hidden>
                                    <div class="role-dashboard-preview__widget-header">
                                        <strong>@widget.Title</strong>
                                        <span>@widget.Description</span>
                                    </div>
                                    <div class="role-dashboard-preview__mock" aria-hidden="true">
                                        <i></i><i></i><i></i><i></i>
                                    </div>
                                </article>
                            }
                        </div>

                        <div class="role-dashboard-preview__empty" data-preview-empty hidden>
                            Günlük Veriler sayfası açılır, ancak bu rol için görünür kart seçilmemiş.
                        </div>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/superadmin-role-edit.js" asp-append-version="true"></script>
}
