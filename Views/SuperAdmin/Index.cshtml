@model List<ONERI.Models.UserListItemViewModel>
@{
    ViewData["Title"] = "Super Admin Paneli";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<div class="container py-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4">
        <div>
            <h1 class="h4 mb-1">Super Admin Paneli</h1>
            <p class="text-muted mb-0">Kullanıcıları ve rolleri yönetin.</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-dark" asp-action="CreateUser">
                <i class="bi bi-person-plus"></i> Yeni Kullanıcı
            </a>
            <a class="btn btn-outline-dark" asp-action="Roles">
                <i class="bi bi-shield-lock"></i> Rol Yetkileri
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Kullanıcı</th>
                            <th>Ad Soyad</th>
                            <th>E-posta</th>
                            <th>Roller</th>
                            <th class="text-end">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            var isCurrentUser = string.Equals(user.Id, currentUserId, StringComparison.Ordinal);
                            var isSuperAdminUser = user.Roles.Contains(Permissions.SuperAdminRole, StringComparer.OrdinalIgnoreCase);
                            var deleteDisabled = isCurrentUser || isSuperAdminUser;
                            var deleteTitle = isCurrentUser
                                ? "Kendi kullanıcınızı silemezsiniz."
                                : isSuperAdminUser
                                    ? "Super Admin kullanıcısı silinemez."
                                    : "Kullanıcıyı sil";
                            <tr>
                                <td>@user.UserName</td>
                                <td>@(string.IsNullOrWhiteSpace(user.AdSoyad) ? "-" : user.AdSoyad)</td>
                                <td>@(string.IsNullOrWhiteSpace(user.Email) ? "-" : user.Email)</td>
                                <td>@(user.Roles.Count == 0 ? "-" : string.Join(", ", user.Roles))</td>
                                <td class="text-end">
                                    <div class="d-inline-flex justify-content-end gap-2">
                                        <a class="btn btn-sm btn-dark" asp-action="EditUser" asp-route-id="@user.Id">
                                            Düzenle
                                        </a>
                                        <form asp-action="DeleteUser"
                                              method="post"
                                              class="d-inline"
                                              onsubmit="return confirm('Bu kullanıcıyı silmek istediğinize emin misiniz?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-danger"
                                                    @(deleteDisabled ? "disabled" : null)
                                                    title="@deleteTitle">
                                                Sil
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
